# Secrets — never commit
.env
.env.*
*.key
*.pem
service-account*.json
credentials*.json

# Terraform — local state + plugins (the terraform/ subdir has its own .gitignore too)
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
**/*.auto.tfvars
**/*.tfplan

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# Node / frontend
node_modules/
dist/
coverage/
*.tsbuildinfo
web/.vite/

# Data — large local files shouldn't go in git (use GCS instead)
/data/
/downloads/
*.parquet
*.csv.gz

# Large EDA per-event panel (~10MB; regenerate via eda/tm_price_eda.py).
# The small summaries, markdown report, and plots ARE committed.
eda/output/tm_price_history_by_event.csv

# IDE / OS
.vscode/
.idea/
.DS_Store

# Claude / AI assistant — local working files, never commit
.claude/
CLAUDE.md
CLAUDE.local.md
plan.md
handoff.md
scratch.md
notes.md
*.plan.md
*.handoff.md

# Internal working drafts — personal notes/messages, never push to teammates
docs/team_messages.md
docs/PROJECT_STRATEGY.md
*.private.md
