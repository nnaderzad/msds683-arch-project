# Keep `gcloud builds submit` uploads small and secret-free. Mirrors .dockerignore
# (the Dockerfile COPY also honors .dockerignore, so terraform/ never reaches an image).
.git/
.claude/
# Root-anchored (leading slash) so these never match a nested dir of the same name,
# e.g. web/src/data/ must NOT be caught by the root data/ rule. Inline '#' comments are
# literal in gitignore syntax, so keep comments on their own line.
# terraform/ holds local tfstate + tfvars (secrets) — never upload.
/terraform/
/data/
/downloads/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
node_modules/
eda/output/
